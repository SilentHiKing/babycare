<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 统计页主体最大宽度，避免横屏时日历和时间轴被拉得过散。 -->
    <dimen name="statistics_content_max_width">520dp</dimen>

    <!-- 统计页当日主区内部统一边距，保证日历、摘要和时间轴共用同一条内容边界。 -->
    <dimen name="statistics_day_content_inset">24dp</dimen>

    <!-- 日历网格在统一内容边界内再留一点呼吸感，避免首尾日期贴近容器边。 -->
    <dimen name="statistics_calendar_grid_inset">0dp</dimen>
    <dimen name="statistics_calendar_nav_button_size">40dp</dimen>
    <dimen name="statistics_calendar_nav_icon_padding">8dp</dimen>

    <!-- 时间轴固定列：左侧轨道 / 右侧时间与内容，保证回看记录时只有一条阅读主线。 -->
    <dimen name="statistics_timeline_rail_width">16dp</dimen>
    <dimen name="statistics_timeline_time_gap">12dp</dimen>
    <dimen name="statistics_timeline_icon_size">40dp</dimen>
    <dimen name="statistics_timeline_content_top_gap">10dp</dimen>
    <dimen name="statistics_timeline_text_gap">12dp</dimen>
    <dimen name="statistics_timeline_item_bottom_gap">10dp</dimen>
    <dimen name="statistics_timeline_last_bottom_gap">22dp</dimen>

    <!-- 事件记录页子类型卡片固定最小高度，压缩首屏高度同时避免长文案导致同行高低不一。 -->
    <dimen name="event_record_subtype_min_height">96dp</dimen>

    <!-- 设置页使用窄列布局，避免平板和横屏时列表被拉得过宽、扫读路径变长。 -->
    <dimen name="settings_content_max_width">560dp</dimen>
    <dimen name="settings_content_bottom_padding">40dp</dimen>
    <dimen name="settings_group_gap">14dp</dimen>
    <dimen name="settings_section_label_padding_top">12dp</dimen>
    <dimen name="settings_section_label_padding_bottom">4dp</dimen>
    <dimen name="settings_section_gap">24dp</dimen>
    <dimen name="settings_section_title_gap">12dp</dimen>
    <dimen name="settings_group_corner_radius">16dp</dimen>
    <dimen name="settings_group_vertical_padding">0dp</dimen>
    <dimen name="settings_row_min_height">52dp</dimen>
    <dimen name="settings_row_vertical_padding">10dp</dimen>
    <dimen name="settings_row_content_gap">12dp</dimen>
    <dimen name="settings_row_arrow_gap">4dp</dimen>
    <dimen name="settings_row_arrow_size">16dp</dimen>
    <dimen name="settings_note_horizontal_padding">4dp</dimen>
    <dimen name="settings_switch_track_width">44dp</dimen>
    <dimen name="settings_switch_track_height">26dp</dimen>
    <dimen name="settings_switch_thumb_size">22dp</dimen>
    <dimen name="settings_switch_corner_radius">999dp</dimen>

    <!-- 侧边栏复用设置页列表语言，保留独立尺寸以便控制抽屉里的视觉密度。 -->
    <dimen name="drawer_width">280dp</dimen>
    <dimen name="drawer_content_horizontal_padding">16dp</dimen>
    <dimen name="drawer_content_vertical_padding">12dp</dimen>
    <dimen name="drawer_profile_row_min_height">88dp</dimen>
    <dimen name="drawer_profile_avatar_size">48dp</dimen>
    <dimen name="drawer_profile_avatar_padding">10dp</dimen>
    <dimen name="drawer_profile_text_gap">12dp</dimen>
    <dimen name="drawer_profile_subtitle_gap">4dp</dimen>
    <dimen name="drawer_menu_icon_size">20dp</dimen>
    <dimen name="drawer_menu_divider_start">56dp</dimen>
</resources>
