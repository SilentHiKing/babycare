<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/drawer_width"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/llDrawerContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/drawer_content_horizontal_padding"
        android:paddingTop="@dimen/drawer_content_vertical_padding"
        android:paddingEnd="@dimen/drawer_content_horizontal_padding"
        android:paddingBottom="@dimen/drawer_content_vertical_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 侧边栏导航合并为单一卡片，减少旧版多卡片带来的碎片感。 -->
        <LinearLayout
            android:id="@+id/llMenuList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_settings_group_surface_border"
            android:orientation="vertical"
            android:paddingVertical="@dimen/settings_group_vertical_padding">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clBabyInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_setting_item_top_ripple"
                android:minHeight="@dimen/drawer_profile_row_min_height"
                android:paddingHorizontal="@dimen/card_padding"
                android:paddingVertical="@dimen/settings_row_vertical_padding">

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="@dimen/drawer_profile_avatar_size"
                    android:layout_height="@dimen/drawer_profile_avatar_size"
                    android:background="@drawable/bg_r999_primary_bg_brand"
                    android:contentDescription="@null"
                    android:padding="@dimen/drawer_profile_avatar_padding"
                    android:src="@drawable/ic_drawer_baby_avatar"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="?attr/colorBrand" />

                <TextView
                    android:id="@+id/tvBabyName"
                    style="@style/TextAppearance.BabyCare.Heading2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/drawer_profile_text_gap"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="?attr/colorTextPrimary"
                    app:layout_constraintEnd_toStartOf="@id/ivArrow"
                    app:layout_constraintStart_toEndOf="@id/ivAvatar"
                    app:layout_constraintTop_toTopOf="@id/ivAvatar"
                    tools:text="hel" />

                <TextView
                    android:id="@+id/tvBabyDays"
                    style="@style/TextAppearance.BabyCare.Label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/drawer_profile_text_gap"
                    android:layout_marginTop="@dimen/drawer_profile_subtitle_gap"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="?attr/colorTextSecondary"
                    app:layout_constraintEnd_toStartOf="@id/ivArrow"
                    app:layout_constraintStart_toEndOf="@id/ivAvatar"
                    app:layout_constraintTop_toBottomOf="@id/tvBabyName"
                    tools:text="已出生 0 天" />

                <ImageView
                    android:id="@+id/ivArrow"
                    android:layout_width="@dimen/settings_row_arrow_size"
                    android:layout_height="@dimen/settings_row_arrow_size"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrow_right"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="?attr/colorTextHint" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                style="@style/divide_horizontal_line"
                android:layout_marginStart="@dimen/drawer_menu_divider_start"
                android:layout_marginEnd="@dimen/card_padding" />

            <LinearLayout
                android:id="@+id/llAllBabies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_setting_item_middle_ripple"
                android:gravity="center_vertical"
                android:minHeight="@dimen/settings_row_min_height"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/card_padding"
                android:paddingVertical="@dimen/settings_row_vertical_padding">

                <ImageView
                    android:layout_width="@dimen/drawer_menu_icon_size"
                    android:layout_height="@dimen/drawer_menu_icon_size"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_all_babies"
                    app:tint="?attr/colorBrand" />

                <TextView
                    style="@style/TextAppearance.BabyCare.Body2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/settings_row_content_gap"
                    android:layout_weight="1"
                    android:includeFontPadding="false"
                    android:text="@string/all_babies"
                    android:textColor="?attr/colorTextPrimary" />

                <ImageView
                    android:layout_width="@dimen/settings_row_arrow_size"
                    android:layout_height="@dimen/settings_row_arrow_size"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="?attr/colorTextHint" />

            </LinearLayout>

            <View
                style="@style/divide_horizontal_line"
                android:layout_marginStart="@dimen/drawer_menu_divider_start"
                android:layout_marginEnd="@dimen/card_padding" />

            <LinearLayout
                android:id="@+id/llSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_setting_item_bottom_ripple"
                android:gravity="center_vertical"
                android:minHeight="@dimen/settings_row_min_height"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/card_padding"
                android:paddingVertical="@dimen/settings_row_vertical_padding">

                <ImageView
                    android:layout_width="@dimen/drawer_menu_icon_size"
                    android:layout_height="@dimen/drawer_menu_icon_size"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings"
                    app:tint="?attr/colorBrand" />

                <TextView
                    style="@style/TextAppearance.BabyCare.Body2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/settings_row_content_gap"
                    android:layout_weight="1"
                    android:includeFontPadding="false"
                    android:text="@string/settings"
                    android:textColor="?attr/colorTextPrimary" />

                <ImageView
                    android:layout_width="@dimen/settings_row_arrow_size"
                    android:layout_height="@dimen/settings_row_arrow_size"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="?attr/colorTextHint" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
