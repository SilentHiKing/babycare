<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <com.zero.components.widget.BaseToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollBackup"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="@dimen/settings_content_bottom_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintWidth_max="@dimen/settings_content_max_width">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/page_horizontal_padding"
            android:paddingTop="@dimen/page_vertical_padding">

            <TextView
                android:id="@+id/tvBackupTitle"
                style="@style/TextAppearance.BabyCare.Heading2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_backup"
                android:textColor="?attr/colorTextPrimary" />

            <LinearLayout
                android:id="@+id/cardBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_section_title_gap"
                android:background="@drawable/bg_settings_group_surface_border"
                android:orientation="vertical"
                android:paddingVertical="@dimen/settings_group_vertical_padding">

                <include
                    android:id="@+id/rowBackupExport"
                    layout="@layout/item_setting_row" />

                <View
                    style="@style/divide_horizontal_line"
                    android:layout_marginStart="@dimen/card_padding"
                    android:layout_marginEnd="@dimen/card_padding" />

                <include
                    android:id="@+id/rowBackupImport"
                    layout="@layout/item_setting_row" />

                <View
                    style="@style/divide_horizontal_line"
                    android:layout_marginStart="@dimen/card_padding"
                    android:layout_marginEnd="@dimen/card_padding" />

                <include
                    android:id="@+id/rowBackupDedup"
                    layout="@layout/item_setting_row" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvBackupNote"
                style="@style/TextAppearance.BabyCare.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_section_title_gap"
                android:paddingHorizontal="@dimen/settings_note_horizontal_padding"
                android:text="@string/backup_note"
                android:textColor="?attr/colorTextHint" />

            <TextView
                android:id="@+id/tvReportTitle"
                style="@style/TextAppearance.BabyCare.Heading2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_section_gap"
                android:text="@string/backup_import_report_title_section"
                android:textColor="?attr/colorTextPrimary" />

            <LinearLayout
                android:id="@+id/cardReportList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_section_title_gap"
                android:background="@drawable/bg_settings_group_surface_border"
                android:orientation="vertical"
                android:paddingVertical="@dimen/settings_group_vertical_padding">

                <include
                    android:id="@+id/rowBackupReportClear"
                    layout="@layout/item_setting_row" />

                <View
                    style="@style/divide_horizontal_line"
                    android:layout_marginStart="@dimen/card_padding"
                    android:layout_marginEnd="@dimen/card_padding" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBackupReports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingVertical="4dp" />

                <TextView
                    android:id="@+id/tvReportEmpty"
                    style="@style/TextAppearance.BabyCare.Label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/card_padding"
                    android:paddingVertical="@dimen/settings_row_vertical_padding"
                    android:text="@string/backup_report_empty"
                    android:textColor="?attr/colorTextHint"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>


