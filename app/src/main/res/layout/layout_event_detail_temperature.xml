<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_event_record_section"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        style="@style/EventDetailFieldLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/temperature_value" />

    <!-- 体温输入 -->
    <LinearLayout
        android:id="@+id/layoutTemperatureInput"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="@dimen/event_detail_label_option_gap"
        android:background="?attr/bg_r6_block_gridview"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <EditText
            android:id="@+id/etTemperature"
            style="@style/TextAppearance.BabyCare.Body1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:gravity="start|center_vertical"
            android:hint="@string/temperature_value_required"
            android:inputType="numberDecimal"
            android:maxLength="4"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="?attr/colorTextPrimary"
            android:textColorHint="?attr/colorTextHint" />

        <TextView
            android:id="@+id/tvTemperatureUnit"
            style="@style/TextAppearance.BabyCare.Heading3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/temperature_unit"
            android:textColor="?attr/colorTextPrimary"
            />

    </LinearLayout>

    <!-- 体温状态提示 -->
    <LinearLayout
        android:id="@+id/llTemperatureStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="?attr/bg_r6_block_gridview"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivStatusIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_check" />

            <TextView
                android:id="@+id/tvStatus"
                style="@style/TextAppearance.BabyCare.Body2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                tools:text="@string/temperature_normal"
                tools:textColor="@color/temp_normal" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvWarning"
            style="@style/TextAppearance.BabyCare.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="28dp"
            android:text="@string/temperature_danger"
            android:textColor="?attr/colorTextSecondary"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

    <!-- 测量部位 -->
    <TextView
        style="@style/EventDetailFieldLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/event_detail_field_gap"
        android:text="@string/temperature_location_label" />

    <RadioGroup
        android:id="@+id/rgTemperatureLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/event_detail_label_option_gap"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbTempEar"
            style="@style/EventDetailRadioButton"
            android:text="@string/temperature_location_ear" />

        <RadioButton
            android:id="@+id/rbTempForehead"
            style="@style/EventDetailRadioButton"
            android:text="@string/temperature_location_forehead" />

        <RadioButton
            android:id="@+id/rbTempArmpit"
            style="@style/EventDetailRadioButton"
            android:text="@string/temperature_location_armpit" />

        <RadioButton
            android:id="@+id/rbTempOral"
            style="@style/EventDetailRadioButton"
            android:text="@string/temperature_location_oral" />

        <RadioButton
            android:id="@+id/rbTempRectal"
            style="@style/EventDetailRadioButton"
            android:text="@string/temperature_location_rectal" />

    </RadioGroup>

</LinearLayout>


