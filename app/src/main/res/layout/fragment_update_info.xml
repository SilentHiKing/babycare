<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <!-- 通用 Toolbar 只承载导航和主操作，宝宝档案对象感放在内容区。 -->
    <com.zero.components.widget.BaseToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:toolbarTitle="@string/babyInfo" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollBabyInfo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/settings_content_bottom_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintWidth_max="@dimen/settings_content_max_width">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/page_horizontal_padding"
            android:paddingTop="@dimen/page_vertical_padding">

            <LinearLayout
                android:id="@+id/cardProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_group_surface_border"
                android:orientation="vertical">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/profileHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="88dp"
                    android:paddingHorizontal="@dimen/card_padding"
                    android:paddingVertical="16dp">

                    <FrameLayout
                        android:id="@+id/profileAvatarContainer"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_toolbar_identity_avatar"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/ivProfileAvatar"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_baby_default"
                            app:tint="?attr/colorBrand" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvProfileTitle"
                        style="@style/TextAppearance.BabyCare.Heading2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="?attr/colorTextPrimary"
                        app:layout_constraintBottom_toTopOf="@id/tvProfileSubtitle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/profileAvatarContainer"
                        app:layout_constraintTop_toTopOf="@id/profileAvatarContainer"
                        app:layout_constraintVertical_chainStyle="packed"
                        tools:text="@string/baby_profile_new_title" />

                    <TextView
                        android:id="@+id/tvProfileSubtitle"
                        style="@style/TextAppearance.BabyCare.Body2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="@string/baby_profile_create_subtitle"
                        android:textColor="?attr/colorTextSecondary"
                        app:layout_constraintBottom_toBottomOf="@id/profileAvatarContainer"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/profileAvatarContainer"
                        app:layout_constraintTop_toBottomOf="@id/tvProfileTitle" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/tvBasicInfoTitle"
                    style="@style/TextAppearance.BabyCare.Label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/card_padding"
                    android:paddingTop="14dp"
                    android:paddingEnd="@dimen/card_padding"
                    android:paddingBottom="4dp"
                    android:text="@string/baby_profile_basic_info"
                    android:textColor="?attr/colorTextSecondary" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/rowName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="@dimen/card_padding">

                    <TextView
                        android:id="@+id/labelName"
                        style="@style/TextAppearance.BabyCare.Body2"
                        android:layout_width="108dp"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="@string/babyName"
                        android:textColor="?attr/colorTextPrimary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/etName"
                        style="@style/TextAppearance.BabyCare.Body1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:hint="@string/babyNameHint"
                        android:imeOptions="actionDone"
                        android:includeFontPadding="false"
                        android:inputType="text"
                        android:maxLines="1"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textColor="?attr/colorTextPrimary"
                        android:textColorHint="?attr/colorTextHint"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/labelName"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    style="@style/divide_horizontal_line"
                    android:layout_marginStart="@dimen/card_padding"
                    android:layout_marginEnd="@dimen/card_padding" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/rowBirthday"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_setting_item_middle_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="@dimen/card_padding">

                    <TextView
                        android:id="@+id/labelBirthday"
                        style="@style/TextAppearance.BabyCare.Body2"
                        android:layout_width="108dp"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="@string/babyBirthday"
                        android:textColor="?attr/colorTextPrimary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/etBirthday"
                        style="@style/TextAppearance.BabyCare.Body1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"
                        android:background="@null"
                        android:cursorVisible="false"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="center_vertical"
                        android:hint="@string/baby_profile_select_birthday"
                        android:includeFontPadding="false"
                        android:inputType="text"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textColor="?attr/colorTextPrimary"
                        android:textColorHint="?attr/colorTextHint"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivBirthdayAction"
                        app:layout_constraintStart_toEndOf="@id/labelBirthday"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/ivBirthdayAction"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_calendar"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/colorTextSecondary" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    style="@style/divide_horizontal_line"
                    android:layout_marginStart="@dimen/card_padding"
                    android:layout_marginEnd="@dimen/card_padding" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/rowGender"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_setting_item_middle_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="@dimen/card_padding">

                    <TextView
                        android:id="@+id/labelGender"
                        style="@style/TextAppearance.BabyCare.Body2"
                        android:layout_width="108dp"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="@string/babyGender"
                        android:textColor="?attr/colorTextPrimary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/etGender"
                        style="@style/TextAppearance.BabyCare.Body1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"
                        android:background="@null"
                        android:cursorVisible="false"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="center_vertical"
                        android:hint="@string/please_select"
                        android:includeFontPadding="false"
                        android:inputType="text"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textColor="?attr/colorTextPrimary"
                        android:textColorHint="?attr/colorTextHint"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivGenderAction"
                        app:layout_constraintStart_toEndOf="@id/labelGender"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/ivGenderAction"
                        android:layout_width="@dimen/settings_row_arrow_size"
                        android:layout_height="@dimen/settings_row_arrow_size"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_arrow_right"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/colorTextHint" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/tvBirthInfoTitle"
                    style="@style/TextAppearance.BabyCare.Label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/card_padding"
                    android:paddingTop="14dp"
                    android:paddingEnd="@dimen/card_padding"
                    android:paddingBottom="4dp"
                    android:text="@string/baby_profile_birth_info"
                    android:textColor="?attr/colorTextSecondary" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/rowWeight"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="@dimen/card_padding">

                    <TextView
                        android:id="@+id/labelWeight"
                        style="@style/TextAppearance.BabyCare.Body2"
                        android:layout_width="108dp"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="@string/babyWeight"
                        android:textColor="?attr/colorTextPrimary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/etWeight"
                        style="@style/TextAppearance.BabyCare.Body1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"
                        android:background="@null"
                        android:digits="0123456789."
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:hint="@string/optional"
                        android:includeFontPadding="false"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textColor="?attr/colorTextPrimary"
                        android:textColorHint="?attr/colorTextHint"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tvWeightUnit"
                        app:layout_constraintStart_toEndOf="@id/labelWeight"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvWeightUnit"
                        style="@style/TextAppearance.BabyCare.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="@string/weight_unit"
                        android:textColor="?attr/colorTextSecondary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    style="@style/divide_horizontal_line"
                    android:layout_marginStart="@dimen/card_padding"
                    android:layout_marginEnd="@dimen/card_padding" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/rowHeight"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="@dimen/card_padding">

                    <TextView
                        android:id="@+id/labelHeight"
                        style="@style/TextAppearance.BabyCare.Body2"
                        android:layout_width="108dp"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="@string/babyHeight"
                        android:textColor="?attr/colorTextPrimary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/etHeight"
                        style="@style/TextAppearance.BabyCare.Body1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"
                        android:background="@null"
                        android:digits="0123456789."
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:hint="@string/optional"
                        android:includeFontPadding="false"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textColor="?attr/colorTextPrimary"
                        android:textColorHint="?attr/colorTextHint"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tvHeightUnit"
                        app:layout_constraintStart_toEndOf="@id/labelHeight"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvHeightUnit"
                        style="@style/TextAppearance.BabyCare.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="@string/height_unit"
                        android:textColor="?attr/colorTextSecondary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    style="@style/divide_horizontal_line"
                    android:layout_marginStart="@dimen/card_padding"
                    android:layout_marginEnd="@dimen/card_padding" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/rowBloodType"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_setting_item_bottom_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="@dimen/card_padding">

                    <TextView
                        android:id="@+id/labelBloodType"
                        style="@style/TextAppearance.BabyCare.Body2"
                        android:layout_width="108dp"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="@string/babyBloodType"
                        android:textColor="?attr/colorTextPrimary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/etBloodType"
                        style="@style/TextAppearance.BabyCare.Body1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"
                        android:background="@null"
                        android:cursorVisible="false"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="center_vertical"
                        android:hint="@string/please_select"
                        android:includeFontPadding="false"
                        android:inputType="text"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textColor="?attr/colorTextPrimary"
                        android:textColorHint="?attr/colorTextHint"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivBloodTypeAction"
                        app:layout_constraintStart_toEndOf="@id/labelBloodType"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/ivBloodTypeAction"
                        android:layout_width="@dimen/settings_row_arrow_size"
                        android:layout_height="@dimen/settings_row_arrow_size"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_arrow_right"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/colorTextHint" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDelete"
                style="@style/TextAppearance.BabyCare.Body1"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_settings_group_surface_border"
                android:gravity="center"
                android:text="@string/delete_baby"
                android:textColor="?attr/semantics_warning_red"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
