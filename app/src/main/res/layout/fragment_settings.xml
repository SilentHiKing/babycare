<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <com.zero.components.widget.BaseToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollSettings"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="@dimen/settings_content_bottom_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintWidth_max="@dimen/settings_content_max_width">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/page_horizontal_padding"
            android:paddingTop="@dimen/page_vertical_padding">

            <!-- 通用设置：单位类选项放在同一组，用户可以连续扫读当前单位。 -->
            <TextView
                android:id="@+id/tvGeneralTitle"
                style="@style/TextAppearance.BabyCare.Heading2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_general"
                android:textColor="?attr/colorTextPrimary" />

            <LinearLayout
                android:id="@+id/cardGeneral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_section_title_gap"
                android:background="@drawable/bg_settings_group_surface_border"
                android:orientation="vertical"
                android:paddingVertical="@dimen/settings_group_vertical_padding">

                <include
                    android:id="@+id/rowFeedingUnit"
                    layout="@layout/item_setting_row" />

                <View
                    style="@style/divide_horizontal_line"
                    android:layout_marginStart="@dimen/card_padding"
                    android:layout_marginEnd="@dimen/card_padding" />

                <include
                    android:id="@+id/rowWeightUnit"
                    layout="@layout/item_setting_row" />

                <View
                    style="@style/divide_horizontal_line"
                    android:layout_marginStart="@dimen/card_padding"
                    android:layout_marginEnd="@dimen/card_padding" />

                <include
                    android:id="@+id/rowHeightUnit"
                    layout="@layout/item_setting_row" />
            </LinearLayout>

            <!-- 提醒设置：保留独立分组，避免权限状态和单位设置混在一起。 -->
            <TextView
                android:id="@+id/tvReminderTitle"
                style="@style/TextAppearance.BabyCare.Heading2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_section_gap"
                android:text="@string/settings_reminder"
                android:textColor="?attr/colorTextPrimary" />

            <LinearLayout
                android:id="@+id/cardReminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_section_title_gap"
                android:background="@drawable/bg_settings_group_surface_border"
                android:orientation="vertical"
                android:paddingVertical="@dimen/settings_group_vertical_padding">

                <include
                    android:id="@+id/rowReminder"
                    layout="@layout/item_setting_switch" />
            </LinearLayout>

            <!-- 关于信息：只展示版本，不使用可点击样式制造错误预期。 -->
            <TextView
                android:id="@+id/tvAboutTitle"
                style="@style/TextAppearance.BabyCare.Heading2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_section_gap"
                android:text="@string/settings_about"
                android:textColor="?attr/colorTextPrimary" />

            <LinearLayout
                android:id="@+id/cardAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_section_title_gap"
                android:background="@drawable/bg_settings_group_surface_border"
                android:orientation="vertical"
                android:paddingVertical="@dimen/settings_group_vertical_padding">

                <include
                    android:id="@+id/rowVersion"
                    layout="@layout/item_setting_row" />
            </LinearLayout>

            <!-- 更多入口：把低频功能放在页面末端，减少高频设置的视觉干扰。 -->
            <TextView
                android:id="@+id/tvMoreTitle"
                style="@style/TextAppearance.BabyCare.Heading2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_section_gap"
                android:text="@string/settings_more"
                android:textColor="?attr/colorTextPrimary" />

            <LinearLayout
                android:id="@+id/cardMore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_section_title_gap"
                android:background="@drawable/bg_settings_group_surface_border"
                android:orientation="vertical"
                android:paddingVertical="@dimen/settings_group_vertical_padding">

                <include
                    android:id="@+id/rowLanguage"
                    layout="@layout/item_setting_row" />

                <View
                    style="@style/divide_horizontal_line"
                    android:layout_marginStart="@dimen/card_padding"
                    android:layout_marginEnd="@dimen/card_padding" />

                <include
                    android:id="@+id/rowBackup"
                    layout="@layout/item_setting_row" />

                <View
                    style="@style/divide_horizontal_line"
                    android:layout_marginStart="@dimen/card_padding"
                    android:layout_marginEnd="@dimen/card_padding" />

                <include
                    android:id="@+id/rowFamily"
                    layout="@layout/item_setting_row" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

