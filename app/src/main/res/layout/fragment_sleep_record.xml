<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <com.zero.components.widget.BaseToolbar
        android:id="@+id/btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/tvSave"
        app:layout_constraintTop_toBottomOf="@id/btn">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/page_horizontal_padding"
            android:paddingBottom="20dp">

            <LinearLayout
                android:id="@+id/cardTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_r16_surface_stroke_control_border"
                android:orientation="vertical"
                android:padding="14dp">

                <com.zero.components.widget.RecordTimerPanelView
                    android:id="@+id/timerPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:endHintText="@string/sleep_end_time"
                    app:endLabelText="@string/sleep_end_time"
                    app:startHintText="@string/sleep_start_time"
                    app:startLabelText="@string/sleep_start_time" />

                <TextView
                    android:id="@+id/tvLastSleep"
                    style="@style/TextAppearance.BabyCare.Label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="?attr/colorTextHint"
                    android:visibility="gone"
                    tools:text="上次: 12-24 06:30"
                    tools:visibility="visible" />

                <TextView
                    style="@style/TextAppearance.BabyCare.Label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/note"
                    android:textColor="?attr/colorTextSecondary" />

                <EditText
                    android:id="@+id/etNote"
                    style="@style/TextAppearance.BabyCare.Body2"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_record_time_field"
                    android:gravity="start|top"
                    android:hint="@string/note_hint"
                    android:inputType="textMultiLine"
                    android:padding="12dp"
                    android:textColor="?attr/colorTextPrimary"
                    android:textColorHint="?attr/colorTextHint" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/tvSave"
        style="@style/TextAppearance.BabyCare.Body1"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="@dimen/page_horizontal_padding"
        android:layout_marginBottom="20dp"
        android:background="?attr/bg_r999_brand_color"
        android:gravity="center"
        android:text="@string/save"
        android:textColor="?attr/colorOnBrand"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
