<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <com.zero.components.widget.BaseToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:toolbarTitle="@string/event_record" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/btnSave"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/sectionTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_event_record_section"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/cardTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_time"
                        app:tint="?attr/colorBrand" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDate"
                            style="@style/TextAppearance.BabyCare.Heading3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="12月25日 周三" />

                        <TextView
                            android:id="@+id/tvTime"
                            style="@style/TextAppearance.BabyCare.Display2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="?attr/colorBrand"
                            tools:text="14:30" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="?attr/colorTextHint" />

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionEventType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_event_record_section"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/TextAppearance.BabyCare.Heading3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/select_event_type" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="7"
                    tools:listitem="@layout/item_event_category" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSubtype"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="4"
                    tools:listitem="@layout/item_event_subtype" />

            </LinearLayout>

            <FrameLayout
                android:id="@+id/sectionDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <FrameLayout
                    android:id="@+id/containerDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <include
                        android:id="@+id/layoutDetailPlaceholder"
                        layout="@layout/layout_event_detail_placeholder"
                        android:visibility="gone" />

                </FrameLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/sectionNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_event_record_section"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tvNoteLabel"
                    style="@style/TextAppearance.BabyCare.Body2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/note"
                    android:textColor="?attr/colorTextPrimary" />

                <EditText
                    android:id="@+id/etNote"
                    style="@style/TextAppearance.BabyCare.Body2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="?attr/bg_r6_block_gridview"
                    android:gravity="top|start"
                    android:hint="@string/note_hint"
                    android:inputType="textMultiLine"
                    android:minHeight="80dp"
                    android:padding="12dp"
                    android:textColor="?attr/colorTextPrimary"
                    android:textColorHint="?attr/colorTextHint" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/btnSave"
        style="@style/TextAppearance.BabyCare.Body1"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="?attr/bg_r999_brand_color"
        android:stateListAnimator="@null"
        android:text="@string/save"
        android:textColor="?attr/colorOnBrand"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
