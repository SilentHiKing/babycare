<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape>
            <solid android:color="?attr/colorBrandLight" />
            <stroke
                android:width="@dimen/surface_stroke_width"
                android:color="?attr/colorBrand" />
            <corners android:radius="@dimen/settings_switch_corner_radius" />
            <size
                android:width="@dimen/settings_switch_track_width"
                android:height="@dimen/settings_switch_track_height" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/control_surface_default" />
            <stroke
                android:width="@dimen/surface_stroke_width"
                android:color="@color/control_border_default" />
            <corners android:radius="@dimen/settings_switch_corner_radius" />
            <size
                android:width="@dimen/settings_switch_track_width"
                android:height="@dimen/settings_switch_track_height" />
        </shape>
    </item>
</selector>
