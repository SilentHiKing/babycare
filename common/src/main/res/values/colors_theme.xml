<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        主题专用颜色定义
        用于 AppTheme.Boy / AppTheme.Girl 主题
    -->

    <!-- ==================== 男孩主题色（Ocean & Cloud - 清爽且可读） ==================== -->
    <!-- Primary: 可承载白字的行动蓝，用于主按钮、选中态与关键强调。 -->
    <color name="boy_brand">#2A74B8</color>
    <color name="boy_brand_dark">#1F5F99</color>
    <color name="boy_brand_light">#D9EAF8</color>
    <!-- Accent: 与行动蓝同源，避免公共组件出现低对比浅蓝文字。 -->
    <color name="boy_accent">#2A74B8</color>
    <!-- Background: 只用于浅背景，不承载白字。 -->
    <color name="boy_bg_brand">#EEF7FE</color>
    <color name="boy_btn_pressed">#1F5F99</color>
    <!-- 带透明度 -->
    <color name="boy_brand_10">#1A2A74B8</color>
    <color name="boy_brand_20">#332A74B8</color>
    <color name="boy_brand_50">#802A74B8</color>

    <!-- ==================== 女孩主题色（Blossom & Cream - 柔和且可读） ==================== -->
    <!-- Primary: 可承载白字的花瓣玫瑰色，用于主按钮、选中态与关键强调。 -->
    <color name="girl_brand">#B8526C</color>
    <color name="girl_brand_dark">#94394F</color>
    <color name="girl_brand_light">#FADBE1</color>
    <!-- Accent: 与行动粉同源，避免浅粉作为正文或图标时对比不足。 -->
    <color name="girl_accent">#B8526C</color>
    <!-- Background: 只用于浅背景，不承载白字。 -->
    <color name="girl_bg_brand">#FFF7F8</color>
    <color name="girl_btn_pressed">#94394F</color>
    <!-- 带透明度 -->
    <color name="girl_brand_10">#1AB8526C</color>
    <color name="girl_brand_20">#33B8526C</color>
    <color name="girl_brand_50">#80B8526C</color>

</resources>
