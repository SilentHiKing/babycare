<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 选中态统一为白底 + 品牌细边框，状态交给 tint 与文字表达。 -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/control_surface_default" />
            <stroke
                android:width="@dimen/surface_stroke_width"
                android:color="?attr/colorBrand" />
            <corners android:radius="?attr/shapeCornerSmall" />
        </shape>
    </item>
    <!-- 未选中状态 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/control_surface_default" />
            <stroke
                android:width="@dimen/surface_stroke_width"
                android:color="@color/control_border_default" />
            <corners android:radius="?attr/shapeCornerSmall" />
        </shape>
    </item>
</selector>

