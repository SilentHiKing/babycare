<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 选中态使用浅暖底和品牌描边，保持事件筛选轻量、可扫读。 -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/control_surface_selected" />
            <stroke
                android:width="@dimen/surface_stroke_width"
                android:color="?attr/colorBrand" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- 默认状态 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/control_surface_default" />
            <stroke
                android:width="@dimen/surface_stroke_width"
                android:color="@color/control_border_default" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</selector>
