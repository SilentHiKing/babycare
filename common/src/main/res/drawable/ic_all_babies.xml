<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!--
        "所有宝宝"图标（柔和双人线性头像·紧凑版）
        设计原因：
        - 整体缩小约 15%，增加 viewport 内留白，
          使视觉重量与 ic_settings 齿轮图标匹配。
        - 前方宝宝头部 r=2.5、后方 r=2，肩部弧线同步收窄，
          图形集中在 viewport 中心区域。
        - 遵循 2dp strokeWidth、round cap/join 统一线性图标规范。
    -->
    <!-- 前方宝宝：头部圆形（中心 9,7.5 半径 2.5） -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M9,10 a2.5,2.5 0 1,0 0,-5 a2.5,2.5 0 0,0 0,5z"
        android:strokeColor="?attr/iconColorPrimary"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="2" />
    <!-- 前方宝宝：肩部弧线 -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M4.5,18.5 C4.5,16 6.5,13 9,13 C11.5,13 13.5,16 13.5,18.5"
        android:strokeColor="?attr/iconColorPrimary"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="2" />
    <!-- 后方宝宝：头部圆形（中心 16,7.5 半径 2） -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M16,9.5 a2,2 0 1,0 0,-4 a2,2 0 0,0 0,4z"
        android:strokeColor="?attr/iconColorPrimary"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="2" />
    <!-- 后方宝宝：右侧肩部弧线 -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M14,13.5 C15.5,13.7 17.5,15.5 18.5,18.5"
        android:strokeColor="?attr/iconColorPrimary"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="2" />
</vector>
